# Copy to `.env.local` for local dev. All `VITE_*` values are embedded in the
# public client bundle — never put secrets here; use GitHub Actions secrets for deploy.

# Google Analytics 4 measurement ID (optional; visitors are tracked when set)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Plausible Analytics (script + optional stats panel on desktop Home)
# VITE_PLAUSIBLE_DOMAIN=robinn.ca
# Plausible Stats API key (Site settings → API) — use a GitHub Actions secret, not this file
# VITE_PLAUSIBLE_API_KEY=

# GitHub PAT for higher API rate limits (desktop Home repo metrics panel)
# VITE_GITHUB_TOKEN=
