    "react-dom": "^19.0.1",
    "react-router-dom": "^7.6.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.33.1",
    "vite": "^6.2.3"
